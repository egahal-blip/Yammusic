# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=  # Список ID пользователей для админ-команд (через запятую), например: 123456789,987654321

# Yandex.Music (опционально)
YANDEX_MUSIC_TOKEN=

# Redis (опционально)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Application
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=30
CACHE_TTL_SECONDS=86400

# API Settings
API_TIMEOUT_SECONDS=10
API_MAX_RETRIES=3

# Webhook Settings
USE_WEBHOOK=false  # true для production, false для разработки (polling)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_PATH=/telegram-webhook
WEBHOOK_URL=https://your-domain.com/telegram-webhook
WEBHOOK_SECRET_TOKEN=  # Секретный токен для webhook (минимум 32 символа) - ОБЯЗАТЕЛЬНО для production
